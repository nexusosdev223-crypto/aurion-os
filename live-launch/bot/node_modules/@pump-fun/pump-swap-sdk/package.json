{
  "name": "@pump-fun/pump-swap-sdk",
  "version": "1.16.0",
  "description": "Official SDK for interacting with Pump Swap AMM protocol on Solana",
  "main": "./dist/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup --clean --dts",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pump-fun/pump-swap-sdk.git"
  },
  "keywords": [
    "pump-swap",
    "pump.fun",
    "solana",
    "web3",
    "defi",
    "amm",
    "sdk",
    "cryptocurrency"
  ],
  "author": {
    "name": "Pump Fun",
    "email": "dev@pump.fun",
    "url": "https://pump.fun"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pump-fun/pump-swap-sdk/issues"
  },
  "homepage": "https://docs.pump.fun",
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-typescript": "^7.22.15",
    "@semantic-release/git": "^10.0.1",
    "@types/bn.js": "^5.1.6",
    "@types/chai": "^4.3.6",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.2",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "chai": "^4.3.10",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.5",
    "semantic-release": "^24.2.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.6",
    "typescript": "~5.2.2"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.2",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm"
    ],
    "branches": [
      {
        "name": "main"
      },
      {
        "name": "devnet",
        "prerelease": true
      }
    ]
  }
}
